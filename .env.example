HIGHLIGHTLY_API_KEY=replace-with-your-highlightly-key
HIGHLIGHTLY_API_BASE_URL=https://soccer.highlightly.net
PORT=4000
HOST=0.0.0.0
FRONTEND_ORIGIN=http://localhost:5173
DEFAULT_TIMEZONE=Europe/Istanbul
DATA_DIR=./apps/api/data
CACHE_DRIVER=redis
DURABLE_STORE=file
REDIS_URL=redis://localhost:6379
LIVE_REFRESH_SECONDS=100
UPCOMING_REFRESH_SECONDS=900
FINISHED_REFRESH_SECONDS=86400
CLIENT_REFRESH_SECONDS=100
